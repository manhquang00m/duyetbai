# === Mau bien moi truong ===
# Copy file nay thanh ".env" roi dien gia tri that.
# TUYET DOI KHONG commit file .env (da nam trong .gitignore).

# Proxy de Node ra internet. Chap nhan cac format:
#   HTTPS_PROXY=http://ip:port                 (khong xac thuc)
#   HTTPS_PROXY=http://user:pass@ip:port        (URL day du, co xac thuc)
#   HTTPS_PROXY=ip:port                         (rut gon)
#   HTTPS_PROXY=ip:port:user:pass               (format nha ban proxy - tu convert)
# De TRONG neu mang khong can proxy.
# LUU Y: neu co user:pass thi day la thong tin dang nhap -> chi de trong .env,
#        KHONG commit, KHONG dan len chat.
# Dung CHUNG 1 bien nay cho MOI tinh nang (Threads scrape, kiem tra link Shopee...) - ket noi
# truc tiep (khong proxy) tren mang cong ty se bi loi TLS
# ("self-signed certificate in certificate chain"), nen luon can dien bien nay.
# Neu dung tren nhieu may kem file phien dang nhap Shopee (.pw-session/shopee.json, xem
# `npm run shopee:login`), nen dat CUNG 1 gia tri proxy tren cac may de tranh bi nghi ngo doi IP.
HTTPS_PROXY=

# Cong chay server
PORT=3000

# Duong dan toi ffmpeg (tinh nang "lam dep video": watermark, filter mau, crop/xoay, toc do).
# De trong neu ffmpeg da co san trong PATH he thong.
FFMPEG_PATH=
